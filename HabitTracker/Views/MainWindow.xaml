<Window x:Class="HabitTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Трекер привычек и продуктивности" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Сайдбар -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,28,24,28" Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="12" Background="{StaticResource PrimaryBrush}">
                        <TextBlock Text="✓" FontSize="22" Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Трекер" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="привычек" Style="{StaticResource Muted}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="NavPanel" Grid.Row="1" Margin="12,0"/>

                <Border Grid.Row="2" Margin="12,0,12,18" Padding="12" Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock x:Name="UserNameText" Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="UserRoleText" Style="{StaticResource Muted}" FontSize="12" Margin="0,2,0,10"/>
                        <Button Content="Выйти" Style="{StaticResource GhostButton}" Click="Logout_Click"
                                HorizontalContentAlignment="Left" Padding="8,8"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Контент -->
        <ContentControl x:Name="ContentArea" Grid.Column="1"/>
    </Grid>
</Window>
