<UserControl x:Class="HabitTracker.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="36,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Пользователи" Style="{StaticResource H1}"/>
            <TextBlock Text="Управление учётными записями" Style="{StaticResource Muted}"
                       FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="20" Margin="0,20,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Имя" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                    <TextBox x:Name="NameBox" Style="{StaticResource InputBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Логин" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                    <TextBox x:Name="LoginBox" Style="{StaticResource InputBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Пароль" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                    <TextBox x:Name="PassBox" Style="{StaticResource InputBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="Роль" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="RoleCombo" Style="{StaticResource InputCombo}"/>
                </StackPanel>
                <Button Grid.Column="8" Content="Добавить" Style="{StaticResource AccentButton}"
                        VerticalAlignment="Bottom" Click="Add_Click"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" x:Name="Grid" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ИМЯ" Binding="{Binding FullName}" Width="*"
                                    ElementStyle="{StaticResource CellText}"/>
                <DataGridTextColumn Header="ЛОГИН" Binding="{Binding Login}" Width="160"
                                    ElementStyle="{StaticResource CellText}"/>
                <DataGridTextColumn Header="РОЛЬ" Binding="{Binding RoleDisplay}" Width="160"
                                    ElementStyle="{StaticResource CellText}"/>
                <DataGridTemplateColumn Header="" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить" Style="{StaticResource GhostButton}"
                                    Padding="12,6" FontSize="12" Height="32"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Click="Delete_Click" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
