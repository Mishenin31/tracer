<Window x:Class="HabitTracker.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Трекер привычек — Вход" Height="700" Width="440"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,16,0,26">
            <Border Width="60" Height="60" CornerRadius="18" Background="{StaticResource PrimaryBrush}"
                    HorizontalAlignment="Left">
                <TextBlock Text="✓" FontSize="32" Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Трекер привычек" Style="{StaticResource H1}" Margin="0,16,0,4"/>
            <TextBlock Text="и продуктивности" Style="{StaticResource Muted}" FontSize="15"/>
        </StackPanel>

        <!-- Переключатель вкладок -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="4" Margin="0,0,0,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="TabLoginBtn" Grid.Column="0" Content="Вход" Click="ShowLogin_Click"
                        Style="{StaticResource PrimaryButton}"/>
                <Button x:Name="TabRegBtn" Grid.Column="1" Content="Регистрация" Click="ShowReg_Click"
                        Style="{StaticResource GhostButton}"/>
            </Grid>
        </Border>

        <!-- Контейнер форм: только одна панель видима за раз -->
        <Grid Grid.Row="2">

            <!-- Форма входа -->
            <StackPanel x:Name="LoginPanel" VerticalAlignment="Top">
                <TextBlock Text="Логин" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                <TextBox x:Name="LoginLogin" Style="{StaticResource InputBox}" Margin="0,0,0,16"/>
                <TextBlock Text="Пароль" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="LoginPassword" Style="{StaticResource InputPassword}" Margin="0,0,0,8"/>
                <TextBlock x:Name="LoginError" Foreground="#FFE57373" FontSize="13" Margin="0,0,0,8"
                           Visibility="Collapsed" TextWrapping="Wrap"/>
                <Button Content="Войти" Style="{StaticResource AccentButton}" Click="Login_Click" Margin="0,8,0,0"/>
                <TextBlock Style="{StaticResource Muted}" Margin="0,20,0,0" TextWrapping="Wrap"
                           Text="Тестовые входы: admin / admin · user / user"/>
            </StackPanel>

            <!-- Форма регистрации -->
            <StackPanel x:Name="RegPanel" VerticalAlignment="Top" Visibility="Collapsed">
                <TextBlock Text="Имя" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                <TextBox x:Name="RegName" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>
                <TextBlock Text="Логин" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                <TextBox x:Name="RegLogin" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>
                <TextBlock Text="Пароль" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="RegPassword" Style="{StaticResource InputPassword}" Margin="0,0,0,8"/>
                <TextBlock x:Name="RegError" Foreground="#FFE57373" FontSize="13" Margin="0,0,0,8"
                           Visibility="Collapsed" TextWrapping="Wrap"/>
                <Button Content="Создать аккаунт" Style="{StaticResource AccentButton}" Click="Register_Click" Margin="0,8,0,0"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>
