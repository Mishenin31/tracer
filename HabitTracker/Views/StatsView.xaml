<UserControl x:Class="HabitTracker.Views.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="36,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Статистика" Style="{StaticResource H1}"/>

        <!-- Карточки -->
        <Grid Grid.Row="1" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="20">
                <StackPanel>
                    <TextBlock Text="Всего привычек" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="TotalHabits" Foreground="{StaticResource TextBrush}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="20">
                <StackPanel>
                    <TextBlock Text="Отметок за неделю" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="WeekChecks" Foreground="{StaticResource AccentBrush}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="20">
                <StackPanel>
                    <TextBlock Text="Задач выполнено" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="TasksDone" Foreground="{StaticResource PrimaryLightBrush}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="20">
                <StackPanel>
                    <TextBlock Text="Лучшая серия" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="BestStreak" Foreground="{StaticResource TextBrush}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Прогресс по привычкам -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="24" Margin="0,20,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Серия по привычкам" Style="{StaticResource H2}" Margin="0,0,0,16"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ProgressList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                                   FontSize="14" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding StreakDisplay}" Foreground="{StaticResource MutedBrush}"
                                                   FontSize="13" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border Grid.Row="1" Height="8" Background="{StaticResource SurfaceAltBrush}"
                                            CornerRadius="4" Margin="0,8,0,0">
                                        <Border HorizontalAlignment="Left" Background="{Binding ColorHex}"
                                                CornerRadius="4" Width="{Binding BarWidth}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
